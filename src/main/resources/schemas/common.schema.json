{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "common.schema.json",
  "title": "Common Types",
  "$comment": "Shared types between Product and UserEvent for Vertex AI Search for Commerce.",

  "$defs": {

    "CustomAttribute": {
      "type": "object",
      "$comment": "Dynamic custom attributes.",
      "properties": {
        "text": {
          "type": "array",
          "items": { "type": "string" }
        },
        "numbers": {
          "type": "array",
          "items": { "type": "number" }
        },
        "searchable": { "type": "boolean" },
        "indexable": { "type": "boolean" }
      }
    },

    "Image": {
      "type": "object",
      "$comment": "Represents a product image.",
      "properties": {
        "uri": { "type": "string" },
        "height": { "type": "integer" },
        "width": { "type": "integer" }
      }
    },

    "PriceInfo": {
      "type": "object",
      "$comment": "Product pricing information.",
      "properties": {
        "currencyCode": { "type": "string" },
        "price": { "type": "number" },
        "originalPrice": { "type": "number" },
        "cost": { "type": "number" },
        "priceEffectiveTime": {
          "type": "string",
          "format": "date-time"
        },
        "priceExpireTime": {
          "type": "string",
          "format": "date-time"
        },
        "priceRange": {
          "type": "object",
          "properties": {
            "price": {
              "$ref": "#/$defs/Interval"
            },
            "originalPrice": {
              "$ref": "#/$defs/Interval"
            }
          }
        }
      }
    },

    "Rating": {
      "type": "object",
      "$comment": "Product rating information.",
      "properties": {
        "ratingCount": { "type": "integer", "minimum": 0},
        "averageRating": {
          "type": "number",
          "minimum": 1,
          "maximum": 5
        },
        "ratingHistogram": {
          "type": "array",
          "$comment": "Always contains EXACTLY 5 positions representing count of 1-star, 2-star, 3-star, 4-star, and 5-star ratings respectively.",
          "minItems": 5,
          "maxItems": 5,
          "items": { "type": "integer", "minimum": 0 }
        }
      }
    },

    "FulfillmentInfo": {
      "type": "object",
      "$comment": "Fulfillment options information.",
      "properties": {
        "type": { "type": "string" },
        "placeIds": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "Audience": {
      "type": "object",
      "$comment": "Product target audience.",
      "properties": {
        "genders": {
          "type": "array",
          "items": { "type": "string" }
        },
        "ageGroups": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "ColorInfo": {
      "type": "object",
      "$comment": "Product color information.",
      "properties": {
        "colorFamilies": {
          "type": "array",
          "items": { "type": "string" }
        },
        "colors": {
          "type": "array",
          "items": { "type": "string" }
        }
      }
    },

    "Promotion": {
      "type": "object",
      "$comment": "Promotion applicable to the product.",
      "properties": {
        "promotionId": { "type": "string" }
      }
    },

    "LocalInventory": {
      "type": "object",
      "$comment": "Product local inventory.",
      "properties": {
        "placeId": { "type": "string" },
        "priceInfo": { "$ref": "#/$defs/PriceInfo" },
        "attributes": {
          "type": "object",
          "additionalProperties": { "$ref": "#/$defs/CustomAttribute" }
        },
        "fulfillmentTypes": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": [
              "pickup-in-store",
              "ship-to-home",
              "same-day-delivery",
              "next-day-delivery",
              "custom-type-1",
              "custom-type-2",
              "custom-type-3",
              "custom-type-4",
              "custom-type-5"
            ]
          }
        }
      }
    },

    "Interval": {
      "type": "object",
      "properties": {
        "minimum": {
          "type": "number"
        },
        "exclusiveMinimum": {
          "type": "number"
        },
        "maximum": {
          "type": "number"
        },
        "exclusiveMaximum": {
          "type": "number"
        }
      },
      "allOf": [
        {
          "oneOf": [
            {
              "required": ["minimum"],
              "not": {
                "required": ["exclusiveMinimum"]
              }
            },
            {
              "required": ["exclusiveMinimum"],
              "not": {
                "required": ["minimum"]
              }
            },
            {
              "not": {
                "anyOf": [
                  { "required": ["minimum"] },
                  { "required": ["exclusiveMinimum"] }
                ]
              }
            }
          ]
        },
        {
          "oneOf": [
            {
              "required": ["maximum"],
              "not": {
                "required": ["exclusiveMaximum"]
              }
            },
            {
              "required": ["exclusiveMaximum"],
              "not": {
                "required": ["maximum"]
              }
            },
            {
              "not": {
                "anyOf": [
                  { "required": ["maximum"] },
                  { "required": ["exclusiveMaximum"] }
                ]
              }
            }
          ]
        }
      ]
    }
  }
}
