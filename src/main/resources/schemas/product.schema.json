{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "product.schema.json",
  "title": "Product",
  "type": "object",
  "$comment": "Complete Product catalog object for Vertex AI Search for Commerce.",

  "required": ["id"],

  "properties": {
    "name": {
      "type": "string",
      "$comment": "Full resource name of the product."
    },
    "id": {
      "type": "string",
      "maxLength": 128,
      "$comment": "Unique and immutable product ID."
    },
    "type": {
      "type": "string",
      "enum": ["PRIMARY", "VARIANT", "COLLECTION"],
      "$comment": "Product type."
    },
    "primaryProductId": {
      "type": "string",
      "$comment": "Primary product ID for variants."
    },
    "collectionMemberIds": {
      "type": "array",
      "items": { "type": "string" },
      "$comment": "Member product IDs for collections."
    },
    "gtin": {
      "type": "string",
      "$comment": "Global Trade Item Number."
    },
    "categories": {
      "type": "array",
      "items": { "type": "string" },
      "$comment": "Hierarchical categories."
    },
    "title": {
      "type": "string",
      "$comment": "Product title."
    },
    "brands": {
      "type": "array",
      "items": { "type": "string" },
      "$comment": "Associated brands."
    },
    "description": {
      "type": "string",
      "$comment": "Text description."
    },
    "languageCode": {
      "type": "string",
      "$comment": "BCP-47 language code."
    },
    "attributes": {
      "type": "object",
      "$comment": "Dynamic custom attributes.",
      "additionalProperties": {
        "$ref": "common.schema.json#/$defs/CustomAttribute"
      }
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "$comment": "Arbitrary tags."
    },
    "priceInfo": {
      "$ref": "common.schema.json#/$defs/PriceInfo"
    },
    "rating": {
      "$ref": "common.schema.json#/$defs/Rating"
    },
    "availableTime": {
      "type": "string",
      "format": "date-time",
      "$comment": "Availability date."
    },
    "availability": {
      "type": "string",
      "enum": ["IN_STOCK", "OUT_OF_STOCK", "PREORDER", "BACKORDER"],
      "$comment": "Inventory status."
    },
    "availableQuantity": {
      "type": "integer",
      "minimum": 0,
      "$comment": "Available quantity."
    },
    "fulfillmentInfo": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/FulfillmentInfo" },
      "$comment": "Fulfillment options."
    },
    "uri": {
      "type": "string",
      "$comment": "Public product URL."
    },
    "images": {
      "type": "array",
      "maxItems": 300,
      "items": { "$ref": "common.schema.json#/$defs/Image" },
      "$comment": "Associated images."
    },
    "audience": {
      "$ref": "common.schema.json#/$defs/Audience"
    },
    "colorInfo": {
      "$ref": "common.schema.json#/$defs/ColorInfo"
    },
    "sizes": {
      "type": "array",
      "items": { "type": "string" },
      "$comment": "Available sizes."
    },
    "materials": {
      "type": "array",
      "items": { "type": "string" },
      "$comment": "Product materials."
    },
    "patterns": {
      "type": "array",
      "items": { "type": "string" },
      "$comment": "Patterns or designs."
    },
    "conditions": {
      "type": "array",
      "items": { "type": "string" },
      "$comment": "Product conditions."
    },
    "promotions": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/Promotion" },
      "$comment": "Applicable promotions."
    },
    "publishTime": {
      "type": "string",
      "format": "date-time",
      "$comment": "Publication date."
    },
    "retrievableFields": {
      "type": "string",
      "$comment": "Returnable fields in searches."
    },
    "variants": {
      "type": "array",
      "$comment": "Product variants (recursive structure).",
      "items": { "$ref": "#" }
    },
    "localInventories": {
      "type": "array",
      "items": { "$ref": "common.schema.json#/$defs/LocalInventory" },
      "$comment": "Local inventories."
    },
    "expireTime": {
      "type": "string",
      "format": "date-time",
      "$comment": "Exact expiration date."
    },
    "ttl": {
      "type": "string",
      "$comment": "Time to live until expiration."
    }
  },

  "oneOf": [
    { "required": ["expireTime"] },
    { "required": ["ttl"] }
  ]
}
