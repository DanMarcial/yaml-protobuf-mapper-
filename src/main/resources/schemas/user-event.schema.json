{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "user-event.schema.json",
  "title": "UserEvent",
  "type": "object",
  "$comment": "UserEvent schema for Vertex AI Search for Commerce. Includes conditional validations by eventType.",

  "required": ["eventType", "visitorId"],

  "properties": {

    "eventType": {
      "type": "string",
      "enum": [
        "add-to-cart",
        "remove-from-cart",
        "category-page-view",
        "detail-page-view",
        "home-page-view",
        "purchase-complete",
        "search",
        "shopping-cart-page-view"
      ]
    },

    "visitorId": {
      "type": "string",
      "maxLength": 128
    },

    "sessionId": {
      "type": "string",
      "maxLength": 128
    },

    "eventTime": {
      "type": "string",
      "format": "date-time"
    },

    "experimentIds": {
      "type": "array",
      "items": { "type": "string" }
    },

    "attributionToken": {
      "type": "string"
    },

    "productDetails": {
      "type": "array",
      "items": { "$ref": "#/$defs/ProductDetail" }
    },

    "completionDetail": {
      "$ref": "#/$defs/CompletionDetail"
    },

    "attributes": {
      "type": "object",
      "additionalProperties": {
        "$ref": "common.schema.json#/$defs/CustomAttribute"
      }
    },

    "cartId": {
      "type": "string"
    },

    "purchaseTransaction": {
      "$ref": "#/$defs/PurchaseTransaction"
    },

    "searchQuery": {
      "type": "string",
      "maxLength": 5000
    },

    "filter": {
      "type": "string",
      "maxLength": 1000
    },

    "orderBy": {
      "type": "string",
      "maxLength": 1000
    },

    "offset": {
      "type": "integer",
      "minimum": 0
    },

    "pageCategories": {
      "type": "array",
      "items": { "type": "string" }
    },

    "userInfo": {
      "$ref": "#/$defs/UserInfo"
    },

    "uri": {
      "type": "string",
      "maxLength": 5000
    },

    "referrerUri": {
      "type": "string",
      "maxLength": 5000
    },

    "pageViewId": {
      "type": "string"
    },

    "entity": {
      "type": "string"
    },

    "panels": {
      "type": "array",
      "items": { "$ref": "#/$defs/PanelInfo" }
    }
  },

  "allOf": [
    {
      "$comment": "SEARCH: requires searchQuery or pageCategories",
      "if": {
        "properties": { "eventType": { "const": "search" } },
        "required": ["eventType"]
      },
      "then": {
        "anyOf": [
          { "required": ["searchQuery"] },
          { "required": ["pageCategories"] }
        ]
      }
    },
    {
      "$comment": "ADD TO CART: requires productDetails",
      "if": {
        "properties": { "eventType": { "const": "add-to-cart" } },
        "required": ["eventType"]
      },
      "then": { "required": ["productDetails"] }
    },
    {
      "$comment": "REMOVE FROM CART: requires productDetails",
      "if": {
        "properties": { "eventType": { "const": "remove-from-cart" } },
        "required": ["eventType"]
      },
      "then": { "required": ["productDetails"] }
    },
    {
      "$comment": "DETAIL PAGE VIEW: requires productDetails",
      "if": {
        "properties": { "eventType": { "const": "detail-page-view" } },
        "required": ["eventType"]
      },
      "then": { "required": ["productDetails"] }
    },
    {
      "$comment": "PURCHASE COMPLETE: requires productDetails and purchaseTransaction",
      "if": {
        "properties": { "eventType": { "const": "purchase-complete" } },
        "required": ["eventType"]
      },
      "then": {
        "required": ["productDetails", "purchaseTransaction"]
      }
    },
    {
      "$comment": "CATEGORY PAGE VIEW: requires pageCategories",
      "if": {
        "properties": { "eventType": { "const": "category-page-view" } },
        "required": ["eventType"]
      },
      "then": { "required": ["pageCategories"] }
    }
  ],

  "$defs": {

    "ProductDetail": {
      "type": "object",
      "$comment": "Represents a product involved in the event.",
      "required": ["product"],
      "properties": {
        "product": {
          "$ref": "product.schema.json"
        },
        "quantity": {
          "type": "integer",
          "minimum": 1
        }
      }
    },

    "CompletionDetail": {
      "type": "object",
      "$comment": "Autocomplete information in search events.",
      "properties": {
        "completion": { "type": "string" },
        "selectedPosition": {
          "type": "integer",
          "minimum": 0
        }
      }
    },

    "PurchaseTransaction": {
      "type": "object",
      "$comment": "Transaction information for purchase-complete.",
      "required": ["id"],
      "properties": {
        "id": { "type": "string" },
        "revenue": { "type": "number" },
        "taxes": { "type": "number" },
        "cost": { "type": "number" },
        "currencyCode": { "type": "string" }
      }
    },

    "UserInfo": {
      "type": "object",
      "$comment": "End user information.",
      "properties": {
        "userId": { "type": "string" },
        "ipAddress": { "type": "string" },
        "userAgent": { "type": "string" },
        "directUserRequest": { "type": "boolean" }
      }
    },

    "PanelInfo": {
      "type": "object",
      "$comment": "Recommendation panel information.",
      "properties": {
        "panelId": { "type": "string" },
        "displayName": { "type": "string" },
        "panelPosition": { "type": "integer" },
        "productDetails": {
          "type": "array",
          "items": { "$ref": "#/$defs/ProductDetail" }
        }
      }
    }

  }
}
