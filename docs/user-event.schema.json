{
  "$schema":"https://json-schema.org/draft/2020-12/schema",
  "title":"UserEvent",
  "type":"object",
  "$comment":"Schema completo de UserEvent para Vertex AI Search for Commerce. Incluye validaciones condicionales por eventType y estructuras anidadas completas.",
  "required":[
    "eventType",
    "visitorId"
  ],
  "properties":{
    "eventType":{
      "type":"string",
      "enum":[
        "add-to-cart",
        "remove-from-cart",
        "category-page-view",
        "detail-page-view",
        "home-page-view",
        "purchase-complete",
        "search",
        "shopping-cart-page-view"
      ]
    },
    "visitorId":{
      "type":"string",
      "maxLength":128
    },
    "sessionId":{
      "type":"string",
      "maxLength":128
    },
    "eventTime":{
      "type":"string",
      "format":"date-time"
    },
    "experimentIds":{
      "type":"array",
      "items":{
        "type":"string"
      }
    },
    "attributionToken":{
      "type":"string"
    },
    "productDetails":{
      "type":"array",
      "items":{
        "$ref":"#/$defs/ProductDetail"
      }
    },
    "completionDetail":{
      "$ref":"#/$defs/CompletionDetail"
    },
    "attributes":{
      "type":"object",
      "additionalProperties":{
        "$ref":"#/$defs/CustomAttribute"
      }
    },
    "cartId":{
      "type":"string"
    },
    "purchaseTransaction":{
      "$ref":"#/$defs/PurchaseTransaction"
    },
    "searchQuery":{
      "type":"string",
      "maxLength":5000
    },
    "filter":{
      "type":"string",
      "maxLength":1000
    },
    "orderBy":{
      "type":"string",
      "maxLength":1000
    },
    "offset":{
      "type":"integer",
      "minimum":0
    },
    "pageCategories":{
      "type":"array",
      "items":{
        "type":"string"
      }
    },
    "userInfo":{
      "$ref":"#/$defs/UserInfo"
    },
    "uri":{
      "type":"string",
      "maxLength":5000
    },
    "referrerUri":{
      "type":"string",
      "maxLength":5000
    },
    "pageViewId":{
      "type":"string"
    },
    "entity":{
      "type":"string"
    },
    "panels":{
      "type":"array",
      "items":{
        "$ref":"#/$defs/PanelInfo"
      }
    }
  },
  "allOf":[
    {
      "$comment":"SEARCH: requiere searchQuery o pageCategories",
      "if":{
        "properties":{
          "eventType":{
            "const":"search"
          }
        }
      },
      "then":{
        "anyOf":[
          {
            "required":[
              "searchQuery"
            ]
          },
          {
            "required":[
              "pageCategories"
            ]
          }
        ]
      }
    },
    {
      "$comment":"ADD TO CART",
      "if":{
        "properties":{
          "eventType":{
            "const":"add-to-cart"
          }
        }
      },
      "then":{
        "required":[
          "productDetails"
        ]
      }
    },
    {
      "$comment":"DETAIL PAGE VIEW",
      "if":{
        "properties":{
          "eventType":{
            "const":"detail-page-view"
          }
        }
      },
      "then":{
        "required":[
          "productDetails"
        ]
      }
    },
    {
      "$comment":"PURCHASE COMPLETE",
      "if":{
        "properties":{
          "eventType":{
            "const":"purchase-complete"
          }
        }
      },
      "then":{
        "required":[
          "productDetails",
          "purchaseTransaction"
        ]
      }
    },
    {
      "$comment":"CATEGORY PAGE VIEW",
      "if":{
        "properties":{
          "eventType":{
            "const":"category-page-view"
          }
        }
      },
      "then":{
        "required":[
          "pageCategories"
        ]
      }
    }
  ],
  "$defs":{
    "ProductDetail":{
      "type":"object",
      "$comment":"Representa un producto involucrado en el evento.",
      "required":[
        "product"
      ],
      "properties":{
        "product":{
          "$ref":"#/$defs/Product"
        },
        "quantity":{
          "type":"integer",
          "minimum":1
        }
      }
    },
    "Product":{
      "type":"object",
      "$comment":"Objeto completo Product del catálogo Retail.",
      "required":[
        "id"
      ],
      "properties":{
        "name":{
          "type":"string",
          "$comment":"Resource name completo del producto."
        },
        "id":{
          "type":"string",
          "maxLength":128,
          "$comment":"ID único e inmutable del producto."
        },
        "type":{
          "type":"string",
          "enum":[
            "PRIMARY",
            "VARIANT",
            "COLLECTION"
          ],
          "$comment":"Tipo de producto."
        },
        "primaryProductId":{
          "type":"string",
          "$comment":"ID del producto primario para variantes."
        },
        "collectionMemberIds":{
          "type":"array",
          "items":{
            "type":"string"
          },
          "$comment":"IDs de productos miembros de colección."
        },
        "gtin":{
          "type":"string",
          "$comment":"Global Trade Item Number."
        },
        "categories":{
          "type":"array",
          "items":{
            "type":"string"
          },
          "$comment":"Categorías jerárquicas."
        },
        "title":{
          "type":"string",
          "$comment":"Título del producto."
        },
        "brands":{
          "type":"array",
          "items":{
            "type":"string"
          },
          "$comment":"Marcas asociadas."
        },
        "description":{
          "type":"string",
          "$comment":"Descripción textual."
        },
        "languageCode":{
          "type":"string",
          "$comment":"Código de idioma BCP-47."
        },
        "attributes":{
          "type":"object",
          "$comment":"Atributos personalizados dinámicos.",
          "additionalProperties":{
            "$ref":"#/$defs/CustomAttribute"
          }
        },
        "tags":{
          "type":"array",
          "items":{
            "type":"string"
          },
          "$comment":"Tags arbitrarios."
        },
        "priceInfo":{
          "$ref":"#/$defs/PriceInfo"
        },
        "rating":{
          "$ref":"#/$defs/Rating"
        },
        "availableTime":{
          "type":"string",
          "format":"date-time",
          "$comment":"Fecha de disponibilidad."
        },
        "availability":{
          "type":"string",
          "enum":[
            "IN_STOCK",
            "OUT_OF_STOCK",
            "PREORDER",
            "BACKORDER"
          ],
          "$comment":"Estado de inventario."
        },
        "availableQuantity":{
          "type":"integer",
          "minimum":0,
          "$comment":"Cantidad disponible."
        },
        "fulfillmentInfo":{
          "type":"array",
          "items":{
            "$ref":"#/$defs/FulfillmentInfo"
          },
          "$comment":"Opciones de fulfillment."
        },
        "uri":{
          "type":"string",
          "$comment":"URL pública del producto."
        },
        "images":{
          "type":"array",
          "maxItems":300,
          "items":{
            "$ref":"#/$defs/Image"
          },
          "$comment":"Imágenes asociadas."
        },
        "audience":{
          "$ref":"#/$defs/Audience"
        },
        "colorInfo":{
          "$ref":"#/$defs/ColorInfo"
        },
        "sizes":{
          "type":"array",
          "items":{
            "type":"string"
          },
          "$comment":"Tallas disponibles."
        },
        "materials":{
          "type":"array",
          "items":{
            "type":"string"
          },
          "$comment":"Materiales del producto."
        },
        "patterns":{
          "type":"array",
          "items":{
            "type":"string"
          },
          "$comment":"Patrones o diseños."
        },
        "conditions":{
          "type":"array",
          "items":{
            "type":"string"
          },
          "$comment":"Condiciones del producto."
        },
        "promotions":{
          "type":"array",
          "items":{
            "$ref":"#/$defs/Promotion"
          },
          "$comment":"Promociones aplicables."
        },
        "publishTime":{
          "type":"string",
          "format":"date-time",
          "$comment":"Fecha de publicación."
        },
        "retrievableFields":{
          "type":"string",
          "$comment":"Campos retornables en búsquedas."
        },
        "variants":{
          "type":"array",
          "$comment":"Variantes del producto (estructura recursiva).",
          "items":{
            "$ref":"#/$defs/Product"
          }
        },
        "localInventories":{
          "type":"array",
          "items":{
            "$ref":"#/$defs/LocalInventory"
          },
          "$comment":"Inventarios locales."
        },
        "expireTime":{
          "type":"string",
          "format":"date-time",
          "$comment":"Fecha exacta de expiración."
        },
        "ttl":{
          "type":"string",
          "$comment":"Duración hasta expiración."
        }
      },
      "oneOf":[
        {
          "required":[
            "expireTime"
          ]
        },
        {
          "required":[
            "ttl"
          ]
        }
      ]
    },
    "PriceInfo":{
      "type":"object",
      "$comment":"Información de precios del producto.",
      "properties":{
        "currencyCode":{
          "type":"string"
        },
        "price":{
          "type":"number"
        },
        "originalPrice":{
          "type":"number"
        },
        "cost":{
          "type":"number"
        },
        "priceEffectiveTime":{
          "type":"string",
          "format":"date-time"
        },
        "priceExpireTime":{
          "type":"string",
          "format":"date-time"
        },
        "priceRange":{
          "type":"object",
          "properties":{
            "price":{
              "type":"number"
            },
            "originalPrice":{
              "type":"number"
            }
          }
        }
      }
    },
    "Rating":{
      "type":"object",
      "properties":{
        "ratingCount":{
          "type":"integer"
        },
        "averageRating":{
          "type":"number"
        },
        "ratingHistogram":{
          "type":"array",
          "items":{
            "type":"integer"
          }
        }
      }
    },
    "FulfillmentInfo":{
      "type":"object",
      "properties":{
        "type":{
          "type":"string"
        },
        "placeIds":{
          "type":"array",
          "items":{
            "type":"string"
          }
        }
      }
    },
    "Image":{
      "type":"object",
      "$comment":"Representa una imagen del producto.",
      "properties":{
        "uri":{
          "type":"string"
        },
        "height":{
          "type":"integer"
        },
        "width":{
          "type":"integer"
        }
      }
    },
    "Audience":{
      "type":"object",
      "properties":{
        "genders":{
          "type":"array",
          "items":{
            "type":"string"
          }
        },
        "ageGroups":{
          "type":"array",
          "items":{
            "type":"string"
          }
        }
      }
    },
    "ColorInfo":{
      "type":"object",
      "properties":{
        "colorFamilies":{
          "type":"array",
          "items":{
            "type":"string"
          }
        },
        "colors":{
          "type":"array",
          "items":{
            "type":"string"
          }
        }
      }
    },
    "Promotion":{
      "type":"object",
      "properties":{
        "promotionId":{
          "type":"string"
        }
      }
    },
    "LocalInventory":{
      "type":"object",
      "properties":{
        "placeId":{
          "type":"string"
        },
        "priceInfo":{
          "$ref":"#/$defs/PriceInfo"
        },
        "attributes":{
          "type":"object",
          "additionalProperties":{
            "$ref":"#/$defs/CustomAttribute"
          }
        },
        "fulfillmentTypes":{
          "type":"array",
          "items":{
            "type":"string"
          }
        },
        "availability":{
          "type":"string",
          "enum":[
            "IN_STOCK",
            "OUT_OF_STOCK",
            "PREORDER",
            "BACKORDER"
          ]
        }
      }
    },
    "CompletionDetail":{
      "type":"object",
      "$comment":"Información de autocomplete en eventos de búsqueda.",
      "properties":{
        "completion":{
          "type":"string"
        },
        "selectedPosition":{
          "type":"integer",
          "minimum":0
        }
      }
    },
    "CustomAttribute":{
      "type":"object",
      "$comment":"Atributos personalizados dinámicos.",
      "properties":{
        "text":{
          "type":"array",
          "items":{
            "type":"string"
          }
        },
        "numbers":{
          "type":"array",
          "items":{
            "type":"number"
          }
        },
        "searchable":{
          "type":"boolean"
        },
        "indexable":{
          "type":"boolean"
        }
      }
    },
    "PurchaseTransaction":{
      "type":"object",
      "$comment":"Información de transacción para purchase-complete.",
      "required":[
        "id"
      ],
      "properties":{
        "id":{
          "type":"string"
        },
        "revenue":{
          "type":"number"
        },
        "taxes":{
          "type":"number"
        },
        "cost":{
          "type":"number"
        },
        "currencyCode":{
          "type":"string"
        }
      }
    },
    "UserInfo":{
      "type":"object",
      "$comment":"Información del usuario final.",
      "properties":{
        "userId":{
          "type":"string"
        },
        "ipAddress":{
          "type":"string"
        },
        "userAgent":{
          "type":"string"
        },
        "directUserRequest":{
          "type":"boolean"
        }
      }
    },
    "PanelInfo":{
      "type":"object",
      "$comment":"Información de paneles de recomendación.",
      "properties":{
        "panelId":{
          "type":"string"
        },
        "displayName":{
          "type":"string"
        },
        "panelPosition":{
          "type":"integer"
        },
        "productDetails":{
          "type":"array",
          "items":{
            "$ref":"#/$defs/ProductDetail"
          }
        }
      }
    }
  }
}